    rdfs:comment "lambda calculus without types"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Lambda_calculus> .

:ComputationalProblem a tbox:FoundationalEntity ;
    rdfs:label "Computational problem"@en ;
    tbox:hasArea ce:FM,
        ce:SE,
