@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix : <http://www.softlang.org/ontologies/fe#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<http://www.softlang.org/ontologies/fe> a owl:Ontology ;
    rdfs:comment "Sub-ontology / ABox for the foundational entities"@en ;
    owl:imports <http://www.softlang.org/ontologies/tbox> .

:ALC a :DescriptionLogic,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "ALC"@en ;
    tbox:hasArea ce:KR,
        ce:TCS ;
    tbox:hasSpace ce:Ontoware ;
    rdfs:comment "basic attributional description logic with complement"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Description_logic> .

:AttributeGrammar a :FormalGrammar,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Attribute grammar"@en ;
    tbox:extends :ContextFreeGrammar ;
    tbox:hasArea ce:CC,
        ce:PLT,
        ce:SLE ;
    tbox:hasSpace ce:Grammarware ;
    tbox:serves :SyntaxDirectedTranslation ;
    tbox:uses :ContextFreeGrammar ;
    rdfs:comment "formal grammar with attributes and semantic rules"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Attribute_grammar> .

:AxiomaticSemantics a :FormalSemanticsApproach,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Axiomatic semantics"@en ;
    tbox:hasArea ce:FM,
        ce:PLT ;
    tbox:hasSpace ce:Programware ;
    tbox:uses :AbstractSyntaxDefinitionApproach,
        :ProgramLogic ;
    rdfs:comment "formal-semantics approach based on axioms and logical proof principles"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Axiomatic_semantics> .

:CalculusOfCommunicatingSystems a :ProcessCalculus,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Calculus of communicating systems"@en ;
    tbox:hasArea ce:PLT,
        ce:TCS ;
    tbox:hasSpace ce:Programware ;
    tbox:isSpecifiedBy :OperationalSemantics ;
    rdfs:comment "calculus for communicating concurrent systems"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Calculus_of_communicating_systems> .

:CategoryTheory a :Theory,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Category theory"@en ;
    tbox:hasArea ce:FM,
        ce:MDE,
        ce:TCS ;
    tbox:hasSpace ce:Modelware ;
    rdfs:comment "mathematical theory of objects and morphisms used widely in abstract modeling and semantics"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Category_theory> .

:CommunicatingSequentialProcesses a :ProcessCalculus,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Communicating sequential processes"@en ;
    tbox:hasArea ce:FM,
        ce:PLT,
        ce:TCS ;
    tbox:hasSpace ce:Programware ;
    tbox:isSpecifiedBy :OperationalSemantics ;
    rdfs:comment "process algebra for communication"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Communicating_sequential_processes> .

:ConstraintSatisfactionProblem a :ComputationalProblem,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Constraint satisfaction problem"@en ;
    tbox:hasArea ce:FM,
        ce:SE,
        ce:TCS ;
    rdfs:comment "computational problem of assigning values so that all specified constraints are satisfied"@en,
        "computational problem of assigning values subject to constraints"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Constraint_satisfaction_problem> .

:DataValidation a :DataManagementApproach,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Data validation"@en ;
    tbox:hasArea ce:SE,
        ce:SLE ;
    tbox:hasSpace ce:JSONware,
        ce:Ontoware,
        ce:SQLware,
        ce:XMLware ;
    rdfs:comment "data-management methodology concerned with checking data quality and conformance to constraints"@en,
        "data-management methodology concerned with ensuring that data conforms to structural and semantic expectations"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Data_validation> .

:DenotationalSemantics a :FormalSemanticsApproach,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Denotational semantics"@en ;
    tbox:hasArea ce:PLT,
        ce:SLE ;
    tbox:hasSpace ce:Programware ;
    tbox:serves :MetaprogrammingApproach,
        :ProgramTransformation ;
    tbox:uses :AbstractSyntaxDefinitionApproach,
        :DomainTheory,
        :LambdaCalculus ;
    rdfs:comment "formal-semantics approach based on mathematical denotations"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Denotational_semantics> .

:DependencyGrammar a :FormalGrammar,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Dependency grammar"@en ;
    tbox:hasArea ce:CL,
        ce:NLP,
        ce:TCS ;
    tbox:hasSpace ce:Grammarware ;
    rdfs:comment "grammar based on dependency relations"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Dependency_grammar> .

:DependencyGraph a :DataStructure,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Dependency graph"@en ;
    tbox:hasArea ce:SE,
        ce:SLE ;
    tbox:hasSpace ce:Graphware ;
    rdfs:comment "data structure representing dependency relations among entities"@en,
        "data-structure notion of a graph used to represent dependency relationships"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Dependency_graph> .

:DesignByContract a :SoftwareDesignApproach,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Design by contract"@en ;
    tbox:hasArea ce:FM,
        ce:SE,
        ce:SLE ;
    tbox:hasSpace ce:APIware ;
    rdfs:comment "software-design methodology based on explicit obligations, guarantees, and contracts"@en,
        "software-design methodology based on formally specified obligations and guarantees"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Design_by_contract> .

:ELPlusPlus a :DescriptionLogic,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "EL++"@en ;
    tbox:hasArea ce:KR,
        ce:TCS ;
    tbox:hasSpace ce:Ontoware ;
    rdfs:comment "lightweight description logic underlying the OWL 2 EL profile"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/EL%2B%2B> .

:FirstOrderLogic a :FormalSystem,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "First-order logic"@en ;
    tbox:hasArea ce:FM,
        ce:KR,
        ce:TCS ;
    tbox:hasSpace ce:Logicware ;
    rdfs:comment "formal system based on quantified predicates over individuals"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/First-order_logic> .

:FormalProof a :FormalObject,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Formal proof"@en ;
    tbox:hasArea ce:FM,
        ce:KR ;
    tbox:hasSpace ce:Logicware,
        ce:Proofware ;
    rdfs:comment "formal object representing a proof in a deductive system"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Formal_proof> .

:Graph a :MathematicalStructure,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Graph"@en ;
    tbox:hasArea ce:FM,
        ce:TCS ;
    tbox:hasSpace ce:Graphware ;
    rdfs:comment "mathematical structure consisting of vertices and edges"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Graph_(discrete_mathematics)> .

:GraphRewritingSystem a :AbstractRewritingSystem,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Graph rewriting system"@en ;
    tbox:hasArea ce:SLE,
        ce:TCS ;
    tbox:hasSpace ce:Graphware ;
    rdfs:comment "rewriting system based on graph transformation rules"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Graph_rewriting> .

:GraphTheory a :Theory,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Graph theory"@en ;
    tbox:hasArea ce:FM,
        ce:TCS ;
    tbox:hasSpace ce:Graphware ;
    rdfs:comment "mathematical theory of graphs and their properties"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Graph_theory> .

:HoareLogic a :ProgramLogic,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Hoare logic"@en ;
    tbox:hasArea ce:FM,
        ce:PLT ;
    tbox:hasSpace ce:Programware,
        ce:Proofware ;
    rdfs:comment "program logic using Hoare triples"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Hoare_logic> .

:HornClause a :FormalObject,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Horn clause"@en ;
    tbox:hasArea ce:KR,
        ce:TCS ;
    tbox:hasSpace ce:Logicware ;
    rdfs:comment "formal object consisting of a clause with at most one positive literal, important in logic programming"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Horn_clause> .

:LambdaMuCalculus a :LambdaCalculus,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Lambda-mu calculus"@en ;
    tbox:hasArea ce:PLT,
        ce:TCS ;
    tbox:hasSpace ce:Programware ;
    rdfs:comment "lambda calculus for classical computation with named continuations"@en ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Lambda-mu_calculus> .

:ModelTransformation a :MetaprogrammingApproach,
        tbox:FoundationalEntity,
        owl:NamedIndividual ;
    rdfs:label "Model transformation"@en ;
    tbox:hasArea ce:MDE,
        ce:SE,
        ce:SLE ;
    tbox:hasSpace ce:Modelware ;
