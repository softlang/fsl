@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix fe: <http://www.softlang.org/ontologies/fe#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<http://www.softlang.org/ontologies/tbox> a owl:Ontology ;
    rdfs:comment "Shared TBox of the FSL ontology"@en ;
    tbox:metamodelingPolicy "Punning/metamodeling is used systematically. Every class that is a subclass of an Entity subclass should also be explicitly typed as that Entity subclass. Every individual whose asserted type derives from an Entity subclass should also be explicitly typed as that Entity subclass. Example: le:QueryLanguage a tbox:LanguageEntity . Example: le:SQL a tbox:LanguageEntity . This expectation should be maintained as the ontology evolves."@en .

tbox:metamodelingPolicy a owl:AnnotationProperty ;
    rdfs:label "metamodeling policy"@en ;
    rdfs:comment "documents the ontology-wide expectation for explicit punning-based typing of classes and individuals with the corresponding Entity subclass"@en .

tbox:Assertion a owl:Class,
        tbox:ConceptualEntity ;
    rdfs:label "Assertion"@en ;
    rdfs:comment "reified assertion entity used for qualified statements in language-related modules"@en ;
    tbox:metamodelingPolicy "Declare every subclass and every individual derived from Assertion explicitly as a ConceptualEntity."@en ;
    rdfs:subClassOf tbox:ConceptualEntity .

tbox:ConceptualEntity rdfs:label "Conceptual entity"@en ;
    rdfs:comment "Contextual concepts for the primary entity types (foundations, languages, tools, and artifacts)"@en ;
    tbox:metamodelingPolicy "Declare every subclass and every individual derived from ConceptualEntity explicitly as a ConceptualEntity."@en ;
    rdfs:subClassOf tbox:Entity .

tbox:SoftwareArtifact a tbox:ArtifactEntity ;
    rdfs:label "Software artifact"@en ;
    rdfs:comment "software artifact kind used to classify the characteristic artifacts of a technological space"@en ;
    rdfs:subClassOf tbox:ArtifactEntity .

tbox:SoftwareTool a tbox:ToolEntity ;
    rdfs:label "Software tool"@en ;
    rdfs:subClassOf tbox:ToolEntity .

tbox:hasAuthorString a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasBibtexKey a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasBooktitle a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasDOI a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasEntryType a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasInclusionRoleComment a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasJournal a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasNumber a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasPages a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasPublicationYear a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:gYear .

tbox:hasPublisher a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasSeries a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasTitle a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:hasURL a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:anyURI .

tbox:hasVolume a owl:DatatypeProperty ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range xsd:string .

tbox:conformsTo a owl:ObjectProperty ;
    rdfs:label "conforms to"@en ;
    rdfs:domain tbox:ArtifactEntity ;
    rdfs:range tbox:ArtifactEntity ;
    owl:inverseOf tbox:hasConformingArtifact .

tbox:describesArtifact a owl:ObjectProperty ;
    rdfs:label "describes artifact"@en ;
    rdfs:domain tbox:ArtifactEntity ;
    rdfs:range tbox:ArtifactEntity ;
    owl:inverseOf tbox:isDescribedByArtifact .

tbox:elementOf a owl:ObjectProperty ;
    rdfs:label "element of"@en ;
    rdfs:domain tbox:ArtifactEntity ;
    rdfs:range tbox:LanguageEntity ;
    owl:inverseOf tbox:hasElement .

tbox:extends a owl:ObjectProperty ;
    rdfs:label "extends"@en ;
    rdfs:comment "relates a software language to another software language that it extends or generalizes"@en ;
    rdfs:domain tbox:SoftwareLanguage ;
    rdfs:range tbox:SoftwareLanguage ;
    owl:inverseOf tbox:isExtendedBy .

tbox:hasArtifact a owl:ObjectProperty ;
    rdfs:label "has artifact"@en ;
    rdfs:domain ce:TechnologicalSpace ;
    rdfs:range tbox:ArtifactEntity ;
    owl:inverseOf tbox:isArtifactOf .

tbox:hasConformingArtifact a owl:ObjectProperty ;
    rdfs:label "has conforming artifact"@en ;
    rdfs:domain tbox:ArtifactEntity ;
    rdfs:range tbox:ArtifactEntity ;
    owl:inverseOf tbox:conformsTo .

tbox:hasElement a owl:ObjectProperty ;
    rdfs:label "has element"@en ;
    rdfs:domain tbox:LanguageEntity ;
    rdfs:range tbox:ArtifactEntity ;
    owl:inverseOf tbox:elementOf .

tbox:hasReferenceEntity a owl:ObjectProperty ;
    rdfs:label "has reference entity"@en ;
    rdfs:domain ce:TechnologicalSpace ;
    rdfs:range tbox:ReferenceEntity ;
    owl:inverseOf tbox:isReferenceEntityFor .

tbox:hasPart a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "has part"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity that is a structural part or constituent of it"@en ;
    rdfs:domain tbox:Entity ;
    rdfs:range tbox:Entity ;
    rdfs:subPropertyOf tbox:uses ;
    owl:inverseOf tbox:isPartOf .

tbox:hasTool a owl:ObjectProperty ;
    rdfs:label "has tool"@en ;
    rdfs:domain ce:TechnologicalSpace ;
    rdfs:range tbox:ToolEntity ;
    owl:inverseOf tbox:isToolOf .

tbox:isAreaOf a owl:ObjectProperty ;
    rdfs:label "is area of"@en ;
    rdfs:comment "relates a subject area to an entity for which it is an important area of interest"@en ;
    rdfs:domain ce:SubjectArea ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( tbox:FoundationalEntity tbox:LanguageEntity fe:FormalSystem fe:ModelOfComputation fe:MethodologicalApproach ) ] ;
    owl:inverseOf tbox:hasArea .

tbox:isArtifactOf a owl:ObjectProperty ;
    rdfs:label "is artifact of"@en ;
    rdfs:domain tbox:ArtifactEntity ;
    rdfs:range ce:TechnologicalSpace ;
    owl:inverseOf tbox:hasArtifact .

tbox:isDescribedByArtifact a owl:ObjectProperty ;
    rdfs:label "is described by artifact"@en ;
    rdfs:domain tbox:ArtifactEntity ;
    rdfs:range tbox:ArtifactEntity ;
    owl:inverseOf tbox:describesArtifact .

tbox:isExtendedBy a owl:ObjectProperty ;
    rdfs:label "is extended by"@en ;
    rdfs:comment "relates a software language to another software language that extends or generalizes it"@en ;
    rdfs:domain tbox:SoftwareLanguage ;
    rdfs:range tbox:SoftwareLanguage ;
    owl:inverseOf tbox:extends .

tbox:isReferenceEntityFor a owl:ObjectProperty ;
    rdfs:label "is reference entity for"@en ;
    rdfs:domain tbox:ReferenceEntity ;
    rdfs:range ce:TechnologicalSpace ;
    owl:inverseOf tbox:hasReferenceEntity .

tbox:isPartOf a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "is part of"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity of which it is a structural part or constituent"@en ;
    rdfs:domain tbox:Entity ;
    rdfs:range tbox:Entity ;
    rdfs:subPropertyOf tbox:isUsedBy ;
    owl:inverseOf tbox:hasPart .

tbox:isProcessedByTool a owl:ObjectProperty ;
    rdfs:label "is processed by tool"@en ;
    rdfs:domain tbox:ArtifactEntity ;
    rdfs:range tbox:ToolEntity ;
    owl:inverseOf tbox:processesArtifact .

tbox:isServedBy a owl:ObjectProperty ;
    rdfs:label "is served by"@en ;
    rdfs:comment "relates a methodological approach to an entity that serves, realizes, supports, or instantiates it in an important way"@en ;
    rdfs:domain fe:MethodologicalApproach ;
    rdfs:range tbox:FoundationalEntity ;
    owl:inverseOf tbox:serves .

tbox:isSpaceOf a owl:ObjectProperty ;
    rdfs:label "is space of"@en ;
    rdfs:comment "relates a technological space to an entity that characteristically belongs to it"@en ;
    rdfs:domain ce:TechnologicalSpace ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( tbox:FoundationalEntity tbox:LanguageEntity fe:FormalSystem fe:ModelOfComputation fe:MethodologicalApproach ) ] ;
    owl:inverseOf tbox:hasSpace .

tbox:isSpecifiedBy a owl:ObjectProperty ;
    rdfs:label "is specified by"@en ;
    rdfs:comment "relates an entity to a methodological approach used to formally specify or define its behavior or meaning"@en ;
    rdfs:domain tbox:FoundationalEntity ;
    rdfs:range fe:MethodologicalApproach ;
    owl:inverseOf tbox:specifies .

tbox:isSupportedByTool a owl:ObjectProperty ;
    rdfs:label "is supported by tool"@en ;
    rdfs:domain tbox:LanguageEntity ;
    rdfs:range tbox:ToolEntity ;
    owl:inverseOf tbox:supportsLanguage .

tbox:isToolOf a owl:ObjectProperty ;
    rdfs:label "is tool of"@en ;
    rdfs:domain tbox:ToolEntity ;
    rdfs:range ce:TechnologicalSpace ;
    owl:inverseOf tbox:hasTool .

tbox:processesArtifact a owl:ObjectProperty ;
    rdfs:label "processes artifact"@en ;
    rdfs:domain tbox:ToolEntity ;
    rdfs:range tbox:ArtifactEntity ;
    owl:inverseOf tbox:isProcessedByTool .

tbox:serves a owl:ObjectProperty ;
    rdfs:label "serves"@en ;
    rdfs:comment "relates an entity to a methodological approach that it serves, realizes, supports, or instantiates in an important way"@en ;
    rdfs:domain tbox:FoundationalEntity ;
    rdfs:range fe:MethodologicalApproach ;
    owl:inverseOf tbox:isServedBy .

tbox:specifies a owl:ObjectProperty ;
    rdfs:label "specifies"@en ;
    rdfs:comment "relates a methodological approach to an entity whose behavior or meaning it is used to formally specify or define"@en ;
    rdfs:domain fe:MethodologicalApproach ;
    rdfs:range tbox:FoundationalEntity ;
    owl:inverseOf tbox:isSpecifiedBy .

tbox:supportsLanguage a owl:ObjectProperty ;
    rdfs:label "supports language"@en ;
    rdfs:domain tbox:ToolEntity ;
    rdfs:range tbox:LanguageEntity ;
    owl:inverseOf tbox:isSupportedByTool .

tbox:isUsedBy a owl:ObjectProperty ;
    rdfs:label "is used by"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity that uses it conceptually, methodologically, or technically"@en ;
    rdfs:domain tbox:Entity ;
    rdfs:range tbox:Entity ;
    owl:inverseOf tbox:uses .

tbox:uses a owl:ObjectProperty ;
    rdfs:label "uses"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity that it uses conceptually, methodologically, or technically"@en ;
    rdfs:domain tbox:Entity ;
    rdfs:range tbox:Entity ;
    owl:inverseOf tbox:isUsedBy .


tbox:hasInputArtifact a owl:ObjectProperty ;
    rdfs:label "Has input artifact"@en ;
    rdfs:comment "relates a software engineering activity or software tool to an artifact kind that it typically requires or consumes as input"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ce:EngineeringActivity tbox:ToolEntity ) ] ;
    rdfs:range tbox:ArtifactEntity .

tbox:hasOutputArtifact a owl:ObjectProperty ;
    rdfs:label "Has output artifact"@en ;
    rdfs:comment "relates a software engineering activity or software tool to an artifact kind that it typically produces as output"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ce:EngineeringActivity tbox:ToolEntity ) ] ;
    rdfs:range tbox:ArtifactEntity .

tbox:hasAffectedArtifact a owl:ObjectProperty ;
    rdfs:label "Has affected artifact"@en ;
    rdfs:comment "relates a software engineering activity or software tool to an artifact kind that it characteristically affects or modifies when the role is not best captured as input or output alone"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ce:EngineeringActivity tbox:ToolEntity ) ] ;
    rdfs:range tbox:ArtifactEntity .

tbox:hasSupportingTool a owl:ObjectProperty ;
    rdfs:label "Has supporting tool"@en ;
    rdfs:comment "relates a software engineering activity to a tool kind that characteristically supports carrying out the activity"@en ;
    rdfs:domain ce:EngineeringActivity ;
    rdfs:range tbox:ToolEntity .

tbox:hasSupportingLanguage a owl:ObjectProperty ;
    rdfs:label "Has supporting language"@en ;
    rdfs:comment "relates a software engineering activity to a language kind that is characteristically used to perform or express the activity"@en ;
    rdfs:domain ce:EngineeringActivity ;
    rdfs:range tbox:LanguageEntity .

tbox:hasSpace a owl:ObjectProperty ;
    rdfs:label "has space"@en ;
    rdfs:comment "associates an entity with a technological space to which it characteristically belongs"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( tbox:FoundationalEntity tbox:LanguageEntity fe:FormalSystem fe:ModelOfComputation fe:MethodologicalApproach ) ] ;
    rdfs:range ce:TechnologicalSpace ;
    owl:inverseOf tbox:isSpaceOf .


tbox:SoftwareLanguage a tbox:LanguageEntity ;
    rdfs:label "Software language"@en ;
    rdfs:comment "Concrete software languages (e.g., XML, SQL, OWL) are represented as individuals of this class. Language families are represented as subclasses. Artifact kinds capture the kinds of artifacts written in such languages."@en ;
    foaf:page <https://en.wikipedia.org/wiki/Software_language> ;
    rdfs:subClassOf tbox:LanguageEntity .

tbox:hasArea a owl:ObjectProperty ;
    rdfs:label "has area"@en ;
    rdfs:comment "identifies an important subject area of interest for a foundational or language entity"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( tbox:FoundationalEntity tbox:LanguageEntity fe:FormalSystem fe:ModelOfComputation fe:MethodologicalApproach ) ] ;
    rdfs:range ce:SubjectArea ;
    owl:inverseOf tbox:isAreaOf .

tbox:ToolEntity rdfs:label "Tool entity"@en ;
    rdfs:comment "ontological entity used to represent software tools, tool families, and tool-related instances"@en ;
    tbox:metamodelingPolicy "Declare every subclass and every individual derived from ToolEntity explicitly as a ToolEntity."@en ;
    rdfs:subClassOf tbox:Entity .

tbox:FoundationalEntity rdfs:label "Foundational entity"@en ;
    rdfs:comment "ontological entity used to represent foundational formalisms, theories, models of computation, and methodological approaches"@en ;
    tbox:metamodelingPolicy "Declare every subclass and every individual derived from FoundationalEntity explicitly as a FoundationalEntity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty tbox:hasArea ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty tbox:hasArea ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:TechnologicalSpace ;
            owl:onProperty tbox:hasSpace ],
        tbox:Entity .

tbox:LanguageEntity rdfs:label "Language entity"@en ;
    rdfs:comment "ontological entity used to represent software languages, language families, and language-related instances"@en ;
    tbox:metamodelingPolicy "Declare every subclass and every individual derived from LanguageEntity explicitly as a LanguageEntity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty tbox:hasArea ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
            owl:onClass ce:SubjectArea ;
            owl:onProperty tbox:hasArea ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass ce:TechnologicalSpace ;
            owl:onProperty tbox:hasSpace ],
        tbox:Entity .

tbox:Entity a owl:Class ;
    rdfs:label "Entity"@en ;
    rdfs:comment "Top-level category for entities represented in this ontology. Entities should be linked to at least one descriptive document via foaf:isPrimaryTopicOf or foaf:page."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty foaf:isPrimaryTopicOf ;
                        owl:someValuesFrom foaf:Document ]
                    [ a owl:Restriction ;
                        owl:onProperty foaf:page ;
                        owl:someValuesFrom foaf:Document ] ) ] .

tbox:ArtifactEntity rdfs:label "Artifact entity"@en ;
    rdfs:comment "ontological entity used to represent software artifacts, artifact families, and artifact-related instances"@en ;
    tbox:metamodelingPolicy "Declare every subclass and every individual derived from ArtifactEntity explicitly as an ArtifactEntity."@en ;
    rdfs:subClassOf tbox:Entity .

tbox:ReferenceEntity a owl:Class ;
    rdfs:label "Reference entity"@en ;
    rdfs:comment "Reference entities are essentially literature references with properties inspired by the BIB format."@en ;
    rdfs:subClassOf tbox:Entity .

