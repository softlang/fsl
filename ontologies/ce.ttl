@prefix : <http://www.softlang.org/ontologies/ce#> .
@prefix ae: <http://www.softlang.org/ontologies/ae#> .
@prefix fe: <http://www.softlang.org/ontologies/fe#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix le: <http://www.softlang.org/ontologies/le#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pe: <http://www.softlang.org/ontologies/pe#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix re: <http://www.softlang.org/ontologies/re#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@prefix te: <http://www.softlang.org/ontologies/te#> .

<http://www.softlang.org/ontologies/ce> a owl:Ontology ;
    rdfs:comment "Sub-ontology / ABox for conceptual entities"@en,
        "This module also hosts the reusable language-concept framework used across software-language modules."@en ;
    owl:imports <http://www.softlang.org/ontologies/tbox> .

:AbstractionConcept a tbox:ConceptualEntity,
        owl:Class ;
    rdfs:subClassOf :PrimitiveConcept .

:AcceptanceTesting a tbox:ConceptualEntity ;
    rdfs:label "Acceptance testing"@en ;
    rdfs:subClassOf :ValidationTestingActivity ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Acceptance_testing> .

:APIDesign a tbox:ConceptualEntity ;
    rdfs:label "API design"@en ;
    tbox:hasOutputArtifact ae:APIDescriptionArtifact ;
    tbox:hasSupportingLanguage le:InterfaceDescriptionLanguage ;
    tbox:hasSupportingTool te:APIWorkbench ;
    tbox:uses fe:SoftwareDesignApproach ;
    rdfs:subClassOf :InterfaceDesign ;
    foaf:page <https://en.wikipedia.org/wiki/API> .

:Auditing a tbox:ConceptualEntity ;
    rdfs:label "Auditing"@en ;
    rdfs:subClassOf :QualityAndGovernanceActivity ;
    foaf:page <https://en.wikipedia.org/wiki/Audit> .

:BackupAndRecovery a tbox:ConceptualEntity ;
    rdfs:label "Backup and recovery"@en ;
    rdfs:subClassOf :OperationsAndMaintenanceActivity ;
    foaf:page <https://en.wikipedia.org/wiki/Backup>,
        <https://en.wikipedia.org/wiki/Data_recovery> .

:BindingConcept a tbox:ConceptualEntity,
        owl:Class ;
    rdfs:subClassOf :PrimitiveConcept .

:BugFixing a tbox:ConceptualEntity ;
    rdfs:label "Bug fixing"@en ;
    rdfs:subClassOf :OperationsAndMaintenanceActivity ;
    foaf:page <https://en.wikipedia.org/wiki/Software_bug> .

:BuildScripting a tbox:ConceptualEntity ;
    rdfs:label "Build scripting"@en ;
    tbox:hasOutputArtifact ae:BuildScriptArtifact ;
    tbox:hasSupportingLanguage le:BuildScriptingLanguage ;
    tbox:hasSupportingTool te:BuildTool ;
    rdfs:subClassOf :ImplementationActivity ;
    foaf:page <https://en.wikipedia.org/wiki/Build_automation> .

:CapacityPlanning a tbox:ConceptualEntity ;
    rdfs:label "Capacity planning"@en ;
    rdfs:subClassOf :OperationsAndMaintenanceActivity ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Capacity_management> .

:ChangeManagement a tbox:ConceptualEntity ;
    rdfs:label "Change management"@en ;
    rdfs:subClassOf :EvolutionAndImprovementActivity ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Change_management> .

:CodeGeneration a :MetaprogrammingConcept,
        tbox:ConceptualEntity ;
    rdfs:label "Code generation"@en ;
    tbox:hasInputArtifact ae:GrammarArtifact,
        ae:ModelArtifact ;
    tbox:hasOutputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage le:ModelTransformationLanguage,
        pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:ModelTransformationEngine ;
    tbox:uses fe:MetaprogrammingApproach ;
    rdfs:subClassOf :Implementation ;
    foaf:isPrimaryTopicOf <https://dbpedia.org/resource/Code_generation_(compiler)>,
        <https://en.wikipedia.org/wiki/Code_generation_(compiler)> ;
    foaf:page <https://en.wikipedia.org/wiki/Code_generation_(compiler)> .

:CodeInspection a tbox:ConceptualEntity ;
    rdfs:label "Code inspection"@en ;
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    rdfs:subClassOf :VerificationActivity ;
    foaf:page <https://en.wikipedia.org/wiki/Software_inspection> .

:CodeReview a tbox:ConceptualEntity ;
    rdfs:label "Code review"@en ;
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    rdfs:subClassOf :ImplementationActivity,
        :VerificationAndValidationActivity ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/Code_review> .

:Coding a tbox:ConceptualEntity ;
    rdfs:label "Coding"@en ;
    tbox:hasOutputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:Compiler,
        te:Interpreter ;
    rdfs:subClassOf :Implementation ;
    foaf:page <https://en.wikipedia.org/wiki/Computer_programming> .

:ComplianceManagement a tbox:ConceptualEntity ;
    rdfs:label "Compliance management"@en ;
    rdfs:subClassOf :QualityAndGovernanceActivity ;
    foaf:page <https://en.wikipedia.org/wiki/Regulatory_compliance> .

