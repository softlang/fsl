:LanguageConcept a tbox:ConceptualEntity,
        owl:Class ;
    rdfs:label "Language concept"@en ;
    rdfs:comment "concept associated with a language framework such as programming-language concepts"@en ;
    rdfs:subClassOf tbox:ConceptualEntity .

:LanguageConceptApplicability a tbox:ConceptualEntity,
        owl:Class ;
    rdfs:label "Language concept applicability"@en ;
    rdfs:comment "qualifier for how directly a language concept applies to a language"@en ;
    rdfs:subClassOf tbox:ConceptualEntity .

:LanguageSupportAssertion a tbox:ConceptualEntity,
        owl:Class ;
    rdfs:label "Language support assertion"@en ;
    rdfs:comment "reified assertion that a language supports a language concept, optionally qualified"@en ;
