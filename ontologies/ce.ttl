#################################################################
# Software Engineering Activity Integration Assertions
#################################################################

ce:RequirementsSpecification
    tbox:hasOutputArtifact ae:RequirementsArtifact ;
    tbox:hasSupportingLanguage le:RequirementsSpecificationLanguage ;
    tbox:hasSupportingTool te:RequirementsTool .

ce:RequirementsAnalysis
    tbox:hasInputArtifact ae:RequirementsArtifact ;
    tbox:hasAffectedArtifact ae:RequirementsArtifact ;
    tbox:hasSupportingLanguage le:RequirementsSpecificationLanguage ;
    tbox:hasSupportingTool te:RequirementsTool .

ce:SystemArchitectureDesign
    tbox:hasSupportingLanguage le:ModelingLanguage ;
    tbox:uses fe:SoftwareDesignApproach .

ce:DataModelDesign
    tbox:hasSupportingLanguage le:DataDefinitionLanguage,
        le:SemanticDataModelLanguage,
        le:OntologyLanguage ;
    tbox:uses fe:DataManagementApproach .

ce:InterfaceDesign
    tbox:hasOutputArtifact ae:APIDescriptionArtifact ;
    tbox:hasSupportingLanguage le:InterfaceDescriptionLanguage ;
    tbox:hasSupportingTool te:APIWorkbench ;
    tbox:uses fe:SoftwareDesignApproach .

ce:APIDesign
    tbox:hasOutputArtifact ae:APIDescriptionArtifact ;
    tbox:hasSupportingLanguage le:InterfaceDescriptionLanguage ;
    tbox:hasSupportingTool te:APIWorkbench ;
    tbox:uses fe:SoftwareDesignApproach .

ce:Prototyping
    tbox:hasOutputArtifact ae:ModelArtifact,
        ae:ProgramArtifact ;
    tbox:hasSupportingLanguage le:ModelingLanguage,
        pe:ProgrammingLanguage ;
    tbox:uses fe:SoftwareDesignApproach .

ce:Implementation
    tbox:hasOutputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:Compiler,
        te:Interpreter ;
    tbox:uses fe:SoftwareDesignApproach .

ce:Coding
    tbox:hasOutputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:Compiler,
        te:Interpreter .

ce:Programming
    tbox:hasOutputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:Compiler,
        te:Interpreter ;
    tbox:uses fe:ModelOfComputation .

ce:CodeGeneration
    tbox:hasInputArtifact ae:ModelArtifact,
        ae:GrammarArtifact ;
    tbox:hasOutputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage le:ModelTransformationLanguage,
        pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:ModelTransformationEngine ;
    tbox:uses fe:MetaprogrammingApproach .

ce:BuildScripting
    tbox:hasOutputArtifact ae:BuildScriptArtifact ;
    tbox:hasSupportingLanguage le:BuildScriptingLanguage ;
    tbox:hasSupportingTool te:BuildTool .

ce:Refactoring
    tbox:hasAffectedArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:RefactoringTool ;
    tbox:uses fe:SoftwareDesignApproach .

ce:StaticAnalysis
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:StaticAnalyzer ;
    tbox:uses fe:ProgramLogic,
        fe:FormalSemanticsApproach .

ce:CodeInspection
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage .

ce:CodeReview
    tbox:hasInputArtifact ae:ProgramArtifact ;
    tbox:hasSupportingLanguage pe:ProgrammingLanguage .

ce:FormalVerification
    tbox:hasInputArtifact ae:ProgramArtifact,
        ae:ModelArtifact ;
    tbox:hasSupportingLanguage le:ProofLanguage,
        le:ModelingLanguage,
        pe:ProgrammingLanguage ;
    tbox:hasSupportingTool te:ProofAssistant ;
    tbox:uses fe:ProgramLogic,
        fe:FormalSemanticsApproach,
        fe:TypeTheory .
