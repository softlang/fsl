[ a owl:AllDisjointClasses ;
    owl:members ( :BuildScriptingLanguage :ConfigurationLanguage :InterfaceDescriptionLanguage :MappingLanguage :MarkupLanguage :Metalanguage :ModelingLanguage :OntologyLanguage :ProofLanguage :RequirementsSpecificationLanguage :RuleLanguage :SchemaLanguage :SemanticDataModelLanguage pe:ProgrammingLanguage ) ] .

:BuildScriptingLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:ConfigurationLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:InterfaceDescriptionLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:MappingLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:MarkupLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:Metalanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:ModelingLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:OntologyLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:ProofLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:RequirementsSpecificationLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:RuleLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:SchemaLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
:SemanticDataModelLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
pe:ProgrammingLanguage owl:disjointWith [ a owl:Class ; owl:unionOf ( :ConstraintLanguage :QueryLanguage :TransformationLanguage :DataManipulationLanguage :DataDefinitionLanguage ) ] .
