@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<http://www.softlang.org/ontologies/le> a owl:Ontology ;
    rdfs:comment "Programming languages are maintained in the pe module; this module keeps non-programming software languages and broad language-kind taxonomies."@en,
        "Sub-ontology / ABox for software languages"@en ;
    owl:imports <http://www.softlang.org/ontologies/ce>,
        <http://www.softlang.org/ontologies/tbox> .

le:ATL a le:ModelTransformationLanguage,
        tbox:LanguageEntity,
        owl:NamedIndividual ;
    rdfs:label "ATL"@en ;
    tbox:hasArea ce:MDE,
        ce:SE,
        ce:SLE ;
    tbox:hasSpace ce:Modelware ;
    foaf:isPrimaryTopicOf <https://en.wikipedia.org/wiki/ATLAS_Transformation_Language> .

