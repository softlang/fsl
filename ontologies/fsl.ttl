:GrammarTransformationEngine a owl:Class , :MetadataEntity ; rdfs:subClassOf :TransformationEngine ; rdfs:label "Grammar transformation engine"@en .
:Compiler a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Compiler"@en .
:Interpreter a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Interpreter"@en .
