:ModelTransformationEngine a owl:Class , :MetadataEntity ; rdfs:subClassOf :TransformationEngine ; rdfs:label "Model transformation engine"@en .
:Validator a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Validator"@en .
