#################################################################
# Literature references
#################################################################

:KurtevBezivinAksit2002TechnologicalSpaces a owl:NamedIndividual , :MetadataEntity , :LiteratureReference ; rdfs:label "Kurtev, Bézivin, and Aksit 2002"@en ; :hasBibtexKey "KurtevBezivinAksit2002TechnologicalSpaces" ; :hasEntryType "inproceedings" ; :hasAuthorString "Ivan Kurtev and Jean Bézivin and Mehmet Aksit" ; :hasTitle "Technological Spaces: An Initial Appraisal" ; :hasBooktitle "Proceedings of the Federated Conferences CoopIS, DOA, and ODBASE 2002, Industrial Track" ; :hasPublicationYear "2002"^^xsd:gYear ; :hasURL "https://www.researchgate.net/profile/Ivan-Kurtev/publication/228580557_Technological_Spaces_An_Initial_Appraisal/links/0fcfd507dd6e6aab8a000000/Technological-Spaces-An-Initial-Appraisal.pdf"^^xsd:anyURI ; :hasInclusionRoleComment "Introduces the concept of technological spaces as ecosystems of related languages, artifacts, tools, and transformations." .
:Bezivin2006MDETechnicalSpace a owl:NamedIndividual , :MetadataEntity , :LiteratureReference ; rdfs:label "Bézivin 2006"@en ; :hasBibtexKey "Bezivin2006MDETechnicalSpace" ; :hasEntryType "incollection" ; :hasAuthorString "Jean Bézivin" ; :hasTitle "Model Driven Engineering: An Emerging Technical Space" ; :hasBooktitle "Generative and Transformational Techniques in Software Engineering" ; :hasSeries "Lecture Notes in Computer Science" ; :hasVolume "4143" ; :hasPages "36--64" ; :hasPublisher "Springer" ; :hasPublicationYear "2006"^^xsd:gYear ; :hasDOI "10.1007/11877028_2" ; :hasInclusionRoleComment "Interprets model-driven engineering as a technological space, illustrating how a space organizes languages, metamodels, and transformations." .
:FavreNguyen2004MegamodelEvolution a owl:NamedIndividual , :MetadataEntity , :LiteratureReference ; rdfs:label "Favre and Nguyen 2004"@en ; :hasBibtexKey "FavreNguyen2004MegamodelEvolution" ; :hasEntryType "inproceedings" ; :hasAuthorString "Jean-Marie Favre and Tam Nguyen" ; :hasTitle "Towards a Megamodel to Model Software Evolution Through Transformations" ; :hasBooktitle "Proceedings of the International Workshop on Software Evolution through Transformations (SETra)" ; :hasPublicationYear "2004"^^xsd:gYear ; :hasURL "https://www.researchgate.net/publication/220369017_Towards_a_Megamodel_to_Model_Software_Evolution_Through_Transformations"^^xsd:anyURI ; :hasInclusionRoleComment "Introduces megamodeling, a framework for modeling languages, artifacts, and transformations; provides the structural basis for representing technological spaces and their interconnections." .
:KlintLaemmelVerhoef2005Grammarware a owl:NamedIndividual , :MetadataEntity , :LiteratureReference ; rdfs:label "Klint, Lämmel, and Verhoef 2005"@en ; :hasBibtexKey "KlintLaemmelVerhoef2005Grammarware" ; :hasEntryType "article" ; :hasAuthorString "Paul Klint and Ralf Lämmel and Chris Verhoef" ; :hasTitle "Toward an Engineering Discipline for Grammarware" ; :hasJournal "ACM Transactions on Software Engineering and Methodology" ; :hasVolume "14" ; :hasNumber "3" ; :hasPages "331--380" ; :hasPublicationYear "2005"^^xsd:gYear ; :hasDOI "10.1145/1072997.1073000" ; :hasURL "https://doi.org/10.1145/1072997.1073000"^^xsd:anyURI ; :hasInclusionRoleComment "Establishes grammarware as a coherent engineering ecosystem, providing a concrete example of a technological space in practice." .
:FavreLaemmelVaranovich2012LinguisticArchitecture a owl:NamedIndividual , :MetadataEntity , :LiteratureReference ; rdfs:label "Favre, Lämmel, and Varanovich 2012"@en ; :hasBibtexKey "FavreLaemmelVaranovich2012LinguisticArchitecture" ; :hasEntryType "inproceedings" ; :hasAuthorString "Jean-Marie Favre and Ralf Lämmel and Andrei Varanovich" ; :hasTitle "Modeling the Linguistic Architecture of Software Products" ; :hasBooktitle "MODELS 2012" ; :hasSeries "Lecture Notes in Computer Science" ; :hasPages "151--167" ; :hasPublisher "Springer" ; :hasPublicationYear "2012"^^xsd:gYear ; :hasDOI "10.1007/978-3-642-33666-9_11" ; :hasInclusionRoleComment "Models the linguistic architecture of software products, strengthening the megamodeling perspective for relating languages, artifacts, and technological spaces." .

:TechnologicalSpace :hasLiteratureReference :KurtevBezivinAksit2002TechnologicalSpaces , :Bezivin2006MDETechnicalSpace , :FavreNguyen2004MegamodelEvolution , :KlintLaemmelVerhoef2005Grammarware , :FavreLaemmelVaranovich2012LinguisticArchitecture .
