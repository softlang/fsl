#################################################################
# Foundational classes and methodological approaches
#################################################################

:FormalSystem a owl:Class ; rdfs:label "Formal system"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Formal_system> ; rdfs:comment "symbolic deductive formal system"@en .
:FormalObject a owl:Class ; rdfs:label "Formal object"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Formalism_(philosophy_of_mathematics)> ; rdfs:comment "formal object used as a mathematically characterized syntactic or symbolic entity"@en .
:Theory a owl:Class ; rdfs:label "Theory"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Theory> ; :hasArea :PLT , :TCS , :FM ; :hasSpace :Programware .
:FormalGrammar a owl:Class , :FoundationalEntity ; rdfs:subClassOf :FormalSystem ; rdfs:label "Formal grammar"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Formal_grammar> ; :hasArea :SLE , :CC , :TCS ; :hasSpace :Grammarware .
:GenerativeGrammar a owl:Class , :FoundationalEntity ; rdfs:subClassOf :FormalGrammar ; rdfs:label "Generative grammar"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Formal_grammar#The_Chomsky_hierarchy> ; :hasArea :CC , :TCS , :CL ; :hasSpace :Grammarware .
:AnalyticGrammar a owl:Class , :FoundationalEntity ; rdfs:subClassOf :FormalGrammar ; rdfs:label "Analytic grammar"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Formal_grammar#Analytic_grammars> ; :hasArea :CC , :SLE , :TCS ; :hasSpace :Grammarware .
:LambdaCalculus a owl:Class , :FoundationalEntity ; rdfs:subClassOf :FormalSystem ; rdfs:label "Lambda calculus"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Lambda_calculus> ; :hasArea :PLT , :TCS ; :hasSpace :Programware .
:LambdaCube a owl:Class , :FoundationalEntity ; rdfs:subClassOf :LambdaCalculus ; rdfs:label "Lambda cube"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Lambda_cube> ; :hasArea :PLT , :TCS ; :hasSpace :Programware .
:ClassicalLambdaCalculus a owl:Class , :FoundationalEntity ; rdfs:subClassOf :LambdaCalculus ; rdfs:label "Classical lambda calculus"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Classical_logic#Lambda_calculi> ; :hasArea :PLT , :TCS ; :hasSpace :Programware .
:TypeTheory a owl:Class , :FoundationalEntity ; rdfs:subClassOf :Theory ; rdfs:label "Type theory"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Type_theory> ; :hasArea :PLT , :TCS , :FM ; :hasSpace :Programware , :Proofware .
:DomainTheory a owl:Class , :FoundationalEntity ; rdfs:subClassOf :Theory ; rdfs:label "Domain theory"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Domain_theory> ; :hasArea :PLT , :TCS , :FM ; :hasSpace :Programware .
:ProgramLogic a owl:Class , :FoundationalEntity ; rdfs:subClassOf :FormalSystem ; rdfs:label "Program logic"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Category:Program_logic> ; :hasArea :FM , :PLT , :TCS ; :hasSpace :Programware .
:DescriptionLogic a owl:Class , :FoundationalEntity ; rdfs:subClassOf :FormalSystem ; rdfs:label "Description logic"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Description_logic> ; :hasArea :KR , :TCS ; :hasSpace :Ontoware .
:ProcessCalculus a owl:Class , :FoundationalEntity ; rdfs:subClassOf :FormalSystem ; rdfs:label "Process calculus"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Process_calculus> ; :hasArea :PLT , :TCS , :FM ; :hasSpace :Programware .
:ModelOfComputation a owl:Class ; rdfs:label "Model of computation"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Model_of_computation> ; rdfs:comment "formal model for representing computation, execution, or state evolution"@en .
:AbstractRewritingSystem a owl:Class , :FoundationalEntity ; rdfs:subClassOf :ModelOfComputation ; rdfs:label "Abstract rewriting system"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Abstract_rewriting_system> ; :hasArea :TCS , :PLT , :SLE ; :hasSpace :Grammarware .
:TransitionSystem a owl:Class , :FoundationalEntity ; rdfs:subClassOf :ModelOfComputation ; rdfs:label "Transition system"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Transition_system> ; :hasArea :PLT , :TCS , :FM ; :hasSpace :Programware .

:MethodologicalApproach a owl:Class ; rdfs:label "Methodological approach"@en ; rdfs:comment "class of foundational entities that represent methodological orientations, techniques, or styles of treatment used in the study or engineering of software languages and related formalisms"@en .
:FormalSemantics a owl:Class , :FoundationalEntity ; rdfs:subClassOf :MethodologicalApproach ; rdfs:label "Formal semantics"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Semantics_(programming_languages)#Approaches> ; :hasArea :PLT , :SLE , :CC ; :hasSpace :Programware .
:SyntaxDefinitionApproach a owl:Class , :FoundationalEntity ; rdfs:subClassOf :MethodologicalApproach ; rdfs:label "Syntax definition approach"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Syntax_(programming_languages)> ; :hasArea :SLE , :CC , :PLT ; :hasSpace :Grammarware .
:Metaprogramming a owl:Class , :FoundationalEntity ; rdfs:subClassOf :MethodologicalApproach ; rdfs:label "Metaprogramming"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Metaprogramming> ; :hasArea :SLE , :CC ; :hasSpace :Programware ; :uses :SyntaxDefinitionApproach .

#################################################################
# Foundational individuals (original ontology preserved, refactored)
#################################################################

:ContextFreeGrammar a owl:NamedIndividual , :FoundationalEntity , :GenerativeGrammar ; rdfs:label "Context-free grammar"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Context-free_grammar> ; rdfs:comment "grammar with context-free productions"@en ; :hasArea :CC , :SLE , :TCS ; :hasSpace :Grammarware ; :serves :DefiningConcreteSyntax .
:RegularGrammar a owl:NamedIndividual , :FoundationalEntity , :GenerativeGrammar ; rdfs:label "Regular grammar"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Regular_grammar> ; rdfs:comment "grammar for regular languages"@en ; :hasArea :CC , :TCS ; :hasSpace :Grammarware ; :serves :DefiningConcreteSyntax .
:ParsingExpressionGrammar a owl:NamedIndividual , :FoundationalEntity , :AnalyticGrammar ; rdfs:label "Parsing expression grammar"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Parsing_expression_grammar> ; rdfs:comment "recognition-based formal grammar"@en ; :hasArea :CC , :SLE ; :hasSpace :Grammarware .
:TDPLGrammar a owl:NamedIndividual , :FoundationalEntity , :AnalyticGrammar ; rdfs:label "TDPL grammar"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Top-down_parsing_language> ; rdfs:comment "recognition-based grammar in the top-down parsing language formalism"@en ; :hasArea :CC , :TCS ; :hasSpace :Grammarware .
:AttributeGrammar a owl:NamedIndividual , :FoundationalEntity , :FormalGrammar ; rdfs:label "Attribute grammar"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Attribute_grammar> ; rdfs:comment "formal grammar with attributes and semantic rules"@en ; :hasArea :CC , :SLE , :PLT ; :hasSpace :Grammarware ; :serves :SyntaxDirectedTranslation ; :extends :ContextFreeGrammar ; :uses :ContextFreeGrammar .
:TermRewritingSystem a owl:NamedIndividual , :FoundationalEntity , :AbstractRewritingSystem ; rdfs:label "Term rewriting system"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Rewriting#Term_rewriting_systems> ; rdfs:comment "rewriting system over algebraic terms"@en ; :hasArea :TCS , :PLT , :SLE ; :hasSpace :Grammarware ; :serves :ProgramTransformation .
:GraphRewritingSystem a owl:NamedIndividual , :FoundationalEntity , :AbstractRewritingSystem ; rdfs:label "Graph rewriting system"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Graph_rewriting> ; rdfs:comment "rewriting system based on graph transformation rules"@en ; :hasArea :TCS , :SLE ; :hasSpace :Graphware .
:TreeTransducer a owl:NamedIndividual , :FoundationalEntity ; rdfs:label "Tree transducer"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Tree_transducer> ; rdfs:comment "formalism for the transformation of trees in a syntax-sensitive manner"@en ; :hasArea :CC , :SLE , :TCS ; :hasSpace :Grammarware ; :serves :ProgramTransformation , :SyntaxDirectedTranslation ; :uses :DefiningAbstractSyntax .
:UntypedLambdaCalculus a owl:NamedIndividual , :FoundationalEntity , :LambdaCalculus , :ClassicalLambdaCalculus ; rdfs:label "Untyped lambda calculus"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Lambda_calculus> ; rdfs:comment "lambda calculus without types"@en ; :hasArea :PLT , :TCS ; :hasSpace :Programware .
:LambdaMuCalculus a owl:NamedIndividual , :FoundationalEntity , :LambdaCalculus ; rdfs:label "Lambda-mu calculus"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Lambda-mu_calculus> ; rdfs:comment "lambda calculus for classical computation with named continuations"@en ; :hasArea :PLT , :TCS ; :hasSpace :Programware .
:SimplyTypedLambdaCalculus a owl:NamedIndividual , :FoundationalEntity , :LambdaCube , :TypeTheory , :ClassicalLambdaCalculus ; rdfs:label "Simply typed lambda calculus"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Simply_typed_lambda_calculus> ; rdfs:comment "typed lambda calculus with simple types"@en ; :hasArea :PLT , :TCS , :FM ; :hasSpace :Programware .
:SystemF a owl:NamedIndividual , :FoundationalEntity , :LambdaCube , :TypeTheory ; rdfs:label "System F"@en ; owl:sameAs <https://en.wikipedia.org/wiki/System_F> ; rdfs:comment "polymorphic typed lambda calculus"@en ; :hasArea :PLT , :TCS ; :hasSpace :Programware .
:DenotationalSemantics a owl:NamedIndividual , :FoundationalEntity , :FormalSemantics ; rdfs:label "Denotational semantics"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Denotational_semantics> ; rdfs:comment "formal-semantics approach based on mathematical denotations"@en ; :hasArea :PLT , :SLE ; :hasSpace :Programware ; :uses :DefiningAbstractSyntax , :LambdaCalculus , :DomainTheory ; :serves :ProgramTransformation , :Metaprogramming .
:OperationalSemantics a owl:NamedIndividual , :FoundationalEntity , :FormalSemantics ; rdfs:label "Operational semantics"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Operational_semantics> ; rdfs:comment "formal-semantics approach based on execution and transition steps"@en ; :hasArea :PLT , :CC , :SLE ; :hasSpace :Programware ; :uses :DefiningAbstractSyntax , :AbstractRewritingSystem , :TransitionSystem ; :serves :ProgramTransformation , :Metaprogramming .
:AxiomaticSemantics a owl:NamedIndividual , :FoundationalEntity , :FormalSemantics ; rdfs:label "Axiomatic semantics"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Axiomatic_semantics> ; rdfs:comment "formal-semantics approach based on axioms and logical proof principles"@en ; :hasArea :FM , :PLT ; :hasSpace :Programware ; :uses :DefiningAbstractSyntax , :ProgramLogic .
:DefiningConcreteSyntax a owl:NamedIndividual , :FoundationalEntity , :SyntaxDefinitionApproach ; rdfs:label "Defining concrete syntax"@en ; rdfs:comment "syntax-definition approach concerned with the explicit surface representation of language constructs, including notation, delimiters, and other syntactically relevant details"@en ; :hasArea :SLE , :CC ; :hasSpace :Grammarware , :Modelware .
:DefiningAbstractSyntax a owl:NamedIndividual , :FoundationalEntity , :SyntaxDefinitionApproach ; rdfs:label "Defining abstract syntax"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Abstract_syntax> ; rdfs:comment "syntax-definition approach concerned with the structural representation of language constructs independently of concrete notation details"@en ; :hasArea :SLE , :PLT , :CC ; :hasSpace :Grammarware , :XMLware , :JSONware , :Modelware .
:ProgramTransformation a owl:NamedIndividual , :FoundationalEntity , :Metaprogramming ; rdfs:label "Program transformation"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Program_transformation> ; rdfs:comment "metaprogramming approach concerned with the systematic transformation of programs or related formal artifacts"@en ; :hasArea :SLE , :CC , :PLT ; :hasSpace :Programware ; :uses :TermRewritingSystem .
:SyntaxDirectedTranslation a owl:NamedIndividual , :FoundationalEntity , :Metaprogramming ; rdfs:label "Syntax-directed translation"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Syntax-directed_translation> ; rdfs:comment "metaprogramming approach concerned with translation processes driven by syntactic structure"@en ; :hasArea :CC , :SLE ; :hasSpace :Grammarware ; :uses :ContextFreeGrammar .
:CommunicatingSequentialProcesses a owl:NamedIndividual , :FoundationalEntity , :ProcessCalculus ; rdfs:label "Communicating sequential processes"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Communicating_sequential_processes> ; rdfs:comment "process algebra for communication"@en ; :hasArea :TCS , :PLT , :FM ; :hasSpace :Programware ; :isSpecifiedBy :OperationalSemantics .
:CalculusOfCommunicatingSystems a owl:NamedIndividual , :FoundationalEntity , :ProcessCalculus ; rdfs:label "Calculus of communicating systems"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Calculus_of_communicating_systems> ; rdfs:comment "calculus for communicating concurrent systems"@en ; :hasArea :TCS , :PLT ; :hasSpace :Programware ; :isSpecifiedBy :OperationalSemantics .
:HoareLogic a owl:NamedIndividual , :FoundationalEntity , :ProgramLogic ; rdfs:label "Hoare logic"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Hoare_logic> ; rdfs:comment "program logic using Hoare triples"@en ; :hasArea :FM , :PLT ; :hasSpace :Programware , :Proofware .
:SeparationLogic a owl:NamedIndividual , :FoundationalEntity , :ProgramLogic ; rdfs:label "Separation logic"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Separation_logic> ; rdfs:comment "program logic for reasoning about mutable heap structures"@en ; :hasArea :FM , :PLT , :SE ; :hasSpace :Programware .
:ALC a owl:NamedIndividual , :FoundationalEntity , :DescriptionLogic ; rdfs:label "ALC"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Description_logic> ; rdfs:comment "basic attributional description logic with complement"@en ; :hasArea :KR , :TCS ; :hasSpace :Ontoware .
:ELPlusPlus a owl:NamedIndividual , :FoundationalEntity , :DescriptionLogic ; rdfs:label "EL++"@en ; owl:sameAs <https://en.wikipedia.org/wiki/EL%2B%2B> ; rdfs:comment "lightweight description logic underlying the OWL 2 EL profile"@en ; :hasArea :KR , :TCS ; :hasSpace :Ontoware .
:DependencyGrammar a owl:NamedIndividual , :FoundationalEntity , :FormalGrammar ; rdfs:label "Dependency grammar"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Dependency_grammar> ; rdfs:comment "grammar based on dependency relations"@en ; :hasArea :CL , :TCS , :NLP ; :hasSpace :Grammarware .

