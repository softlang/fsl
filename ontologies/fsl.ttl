:QueryProcessor a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Query processor"@en .
:XMLProcessor a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "XML processor"@en .
:JSONProcessor a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "JSON processor"@en .
:RelationalDatabaseManagementSystem a owl:Class , :MetadataEntity ; rdfs:subClassOf :QueryProcessor , :Validator ; rdfs:label "Relational database management system"@en .
:TripleStore a owl:Class , :MetadataEntity ; rdfs:subClassOf :QueryProcessor ; rdfs:label "Triple store"@en .
:Reasoner a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Reasoner"@en .
:OntologyEditor a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Ontology editor"@en .
:GraphDatabaseManagementSystem a owl:Class , :MetadataEntity ; rdfs:subClassOf :QueryProcessor ; rdfs:label "Graph database management system"@en .
:APIWorkbench a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "API workbench"@en .
:RuleEngine a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Rule engine"@en .
:LogicProgrammingSystem a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Logic programming system"@en .
:ProofAssistant a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Proof assistant"@en .
:MarkupProcessor a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Markup processor"@en .

:ParserGenerator :processesArtifactKind :GrammarArtifact ; :supportsLanguage :GrammarMetalanguage .
:GrammarAnalyzer :processesArtifactKind :GrammarArtifact ; :supportsLanguage :GrammarMetalanguage .
:GrammarTransformationEngine :processesArtifactKind :GrammarArtifact ; :supportsLanguage :GrammarTransformationLanguage .
:Compiler :processesArtifactKind :ProgramArtifact ; :supportsLanguage :ProgrammingLanguage .
:Interpreter :processesArtifactKind :ProgramArtifact ; :supportsLanguage :ProgrammingLanguage .
:StaticAnalyzer :processesArtifactKind :ProgramArtifact ; :supportsLanguage :ProgrammingLanguage .
:ModelTransformationEngine :processesArtifactKind :ModelArtifact , :MetamodelArtifact ; :supportsLanguage :ModelTransformationLanguage .
:ModelValidator :processesArtifactKind :ModelArtifact ; :supportsLanguage :ConstraintLanguage .
:ModelingWorkbench :processesArtifactKind :ModelArtifact , :MetamodelArtifact ; :supportsLanguage :ModelingLanguage , :MetamodelingLanguage .
:XMLProcessor :processesArtifactKind :XMLDocumentArtifact , :XMLSchemaArtifact ; :supportsLanguage :XML , :XMLSchemaLanguage , :XMLQueryLanguage , :DocumentTransformationLanguage .
:JSONProcessor :processesArtifactKind :JSONDocumentArtifact , :JSONSchemaArtifact ; :supportsLanguage :JSON , :JSONSchemaLanguage , :JSONQueryLanguage .
:RelationalDatabaseManagementSystem :processesArtifactKind :RelationalSchemaArtifact , :RelationalDataArtifact , :RelationalQueryArtifact ; :supportsLanguage :SQL , :SQLDDL , :SQLDML , :SQLQuery .
:TripleStore :processesArtifactKind :RDFGraphArtifact ; :supportsLanguage :RDF , :SPARQL .
:Reasoner :processesArtifactKind :OntologyArtifact , :RDFGraphArtifact ; :supportsLanguage :OntologyLanguage , :SemanticDataModelLanguage .
:OntologyEditor :processesArtifactKind :OntologyArtifact ; :supportsLanguage :OntologyLanguage .
:GraphDatabaseManagementSystem :processesArtifactKind :PropertyGraphArtifact , :GraphQueryArtifact ; :supportsLanguage :PropertyGraphDataModelLanguage , :GraphQueryLanguage .
:APIWorkbench :processesArtifactKind :APIDescriptionArtifact ; :supportsLanguage :InterfaceDescriptionLanguage .
:RuleEngine :processesArtifactKind :RuleArtifact ; :supportsLanguage :RuleLanguage .
:LogicProgrammingSystem :processesArtifactKind :LogicProgramArtifact ; :supportsLanguage :LogicProgrammingLanguage .
:ProofAssistant :processesArtifactKind :ProofArtifact ; :supportsLanguage :ProofLanguage .
:MarkupProcessor :processesArtifactKind :MarkupArtifact ; :supportsLanguage :MarkupLanguage .

:Grammarware :hasArtifactKind :GrammarArtifact ; :hasToolKind :ParserGenerator , :GrammarAnalyzer , :GrammarTransformationEngine .
:Modelware :hasArtifactKind :ModelArtifact , :MetamodelArtifact ; :hasToolKind :ModelingWorkbench , :ModelTransformationEngine , :ModelValidator .
:Programware :hasArtifactKind :ProgramArtifact ; :hasToolKind :Compiler , :Interpreter , :StaticAnalyzer .
:XMLware :hasArtifactKind :XMLDocumentArtifact , :XMLSchemaArtifact ; :hasToolKind :XMLProcessor , :Validator , :QueryProcessor , :TransformationEngine .
:JSONware :hasArtifactKind :JSONDocumentArtifact , :JSONSchemaArtifact ; :hasToolKind :JSONProcessor , :Validator , :QueryProcessor , :TransformationEngine .
:SQLware :hasArtifactKind :RelationalSchemaArtifact , :RelationalDataArtifact , :RelationalQueryArtifact ; :hasToolKind :RelationalDatabaseManagementSystem , :QueryProcessor , :Validator .
:Ontoware :hasArtifactKind :RDFGraphArtifact , :OntologyArtifact , :ShapeArtifact ; :hasToolKind :TripleStore , :Reasoner , :OntologyEditor , :Validator , :QueryProcessor .
:Graphware :hasArtifactKind :PropertyGraphArtifact , :GraphQueryArtifact ; :hasToolKind :GraphDatabaseManagementSystem , :QueryProcessor , :TransformationEngine .
:APIware :hasArtifactKind :APIDescriptionArtifact ; :hasToolKind :APIWorkbench , :Validator , :TransformationEngine .
:Ruleware :hasArtifactKind :RuleArtifact ; :hasToolKind :RuleEngine , :Validator .
:Logicware :hasArtifactKind :LogicProgramArtifact ; :hasToolKind :LogicProgrammingSystem , :Reasoner .
:Proofware :hasArtifactKind :ProofArtifact ; :hasToolKind :ProofAssistant .
:Markupware :hasArtifactKind :MarkupArtifact ; :hasToolKind :MarkupProcessor , :TransformationEngine .

