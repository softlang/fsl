@prefix : <http://www.softlang.org/ontologies/fsl/> .
@prefix fsl: <http://www.softlang.org/ontologies/fsl/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://www.softlang.org/ontologies/fsl/> .

#################################################################
# Ontology
#################################################################

<http://www.softlang.org/ontologies/fsl>
    a owl:Ontology ;
    rdfs:label "Foundations of Software Languages (FSL)"@en ;
    rdfs:comment "Ontology on the foundations of software languages, including language entities, foundational entities, methodological approaches, technological spaces, tools, and related metadata."@en .

#################################################################
# Core meta-classes
#################################################################

:OntologyEntity
    a owl:Class ;
    rdfs:label "Ontology entity"@en ;
    rdfs:comment "top-level category for entities represented in this ontology"@en .

:LanguageEntity
    a owl:Class ;
    rdfs:subClassOf
        :OntologyEntity ,
        [ a owl:Restriction ; owl:onProperty :hasArea ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :SubjectArea ] ,
        [ a owl:Restriction ; owl:onProperty :hasArea ; owl:maxQualifiedCardinality "3"^^xsd:nonNegativeInteger ; owl:onClass :SubjectArea ] ,
        [ a owl:Restriction ; owl:onProperty :hasSpace ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :TechnologicalSpace ] ;
    rdfs:label "Language entity"@en ;
    rdfs:comment "ontological entity used to represent software languages, language families, and language-related instances"@en .

:FoundationalEntity
    a owl:Class ;
    rdfs:subClassOf
        :OntologyEntity ,
        [ a owl:Restriction ; owl:onProperty :hasArea ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :SubjectArea ] ,
        [ a owl:Restriction ; owl:onProperty :hasArea ; owl:maxQualifiedCardinality "3"^^xsd:nonNegativeInteger ; owl:onClass :SubjectArea ] ,
        [ a owl:Restriction ; owl:onProperty :hasSpace ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :TechnologicalSpace ] ;
    rdfs:label "Foundational entity"@en ;
    rdfs:comment "ontological entity used to represent foundational formalisms, theories, models of computation, and methodological approaches"@en .

:MetadataEntity
    a owl:Class ;
    rdfs:subClassOf :OntologyEntity ;
    rdfs:label "Metadata entity"@en ;
    rdfs:comment "ontological entity used for metadata, classificatory, or supporting purposes"@en .

#################################################################
# Core properties
#################################################################

:hasArea
    a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :FoundationalEntity :LanguageEntity :FormalSystem :ModelOfComputation :MethodologicalApproach ) ] ;
    rdfs:range :SubjectArea ;
    owl:inverseOf :isAreaOf ;
    rdfs:label "has area"@en ;
    rdfs:comment "identifies an important subject area of interest for a foundational or language entity"@en .

:isAreaOf
    a owl:ObjectProperty ;
    rdfs:domain :SubjectArea ;
    rdfs:range [ a owl:Class ; owl:unionOf ( :FoundationalEntity :LanguageEntity :FormalSystem :ModelOfComputation :MethodologicalApproach ) ] ;
    owl:inverseOf :hasArea ;
    rdfs:label "is area of"@en ;
    rdfs:comment "relates a subject area to an entity for which it is an important area of interest"@en .

:hasSpace
    a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :FoundationalEntity :LanguageEntity :FormalSystem :ModelOfComputation :MethodologicalApproach ) ] ;
    rdfs:range :TechnologicalSpace ;
    owl:inverseOf :isSpaceOf ;
    rdfs:label "has space"@en ;
    rdfs:comment "associates an entity with a technological space to which it characteristically belongs"@en .

:isSpaceOf
    a owl:ObjectProperty ;
    rdfs:domain :TechnologicalSpace ;
    rdfs:range [ a owl:Class ; owl:unionOf ( :FoundationalEntity :LanguageEntity :FormalSystem :ModelOfComputation :MethodologicalApproach ) ] ;
    owl:inverseOf :hasSpace ;
    rdfs:label "is space of"@en ;
    rdfs:comment "relates a technological space to an entity that characteristically belongs to it"@en .

:uses
    a owl:ObjectProperty ;
    rdfs:domain :OntologyEntity ;
    rdfs:range :OntologyEntity ;
    owl:inverseOf :isUsedBy ;
    rdfs:label "uses"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity that it uses conceptually, methodologically, or technically"@en .

:isUsedBy
    a owl:ObjectProperty ;
    rdfs:domain :OntologyEntity ;
    rdfs:range :OntologyEntity ;
    owl:inverseOf :uses ;
    rdfs:label "is used by"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity that uses it conceptually, methodologically, or technically"@en .

:hasPart
    a owl:ObjectProperty , owl:AsymmetricProperty , owl:IrreflexiveProperty ;
    rdfs:subPropertyOf :uses ;
    rdfs:domain :OntologyEntity ;
    rdfs:range :OntologyEntity ;
    owl:inverseOf :isPartOf ;
    rdfs:label "has part"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity that is a structural part or constituent of it"@en .

:isPartOf
    a owl:ObjectProperty , owl:AsymmetricProperty , owl:IrreflexiveProperty ;
    rdfs:subPropertyOf :isUsedBy ;
    rdfs:domain :OntologyEntity ;
    rdfs:range :OntologyEntity ;
    owl:inverseOf :hasPart ;
    rdfs:label "is part of"@en ;
    rdfs:comment "relates an ontology entity to another ontology entity of which it is a structural part or constituent"@en .

:extends
    a owl:ObjectProperty ;
    rdfs:domain :SoftwareLanguage ;
    rdfs:range :SoftwareLanguage ;
    owl:inverseOf :isExtendedBy ;
    rdfs:label "extends"@en ;
    rdfs:comment "relates a software language to another software language that it extends or generalizes"@en .

:isExtendedBy
    a owl:ObjectProperty ;
    rdfs:domain :SoftwareLanguage ;
    rdfs:range :SoftwareLanguage ;
    owl:inverseOf :extends ;
    rdfs:label "is extended by"@en ;
    rdfs:comment "relates a software language to another software language that extends or generalizes it"@en .

:serves
    a owl:ObjectProperty ;
    rdfs:domain :FoundationalEntity ;
    rdfs:range :MethodologicalApproach ;
    owl:inverseOf :isServedBy ;
    rdfs:label "serves"@en ;
    rdfs:comment "relates an entity to a methodological approach that it serves, realizes, supports, or instantiates in an important way"@en .

:isServedBy
    a owl:ObjectProperty ;
    rdfs:domain :MethodologicalApproach ;
    rdfs:range :FoundationalEntity ;
    owl:inverseOf :serves ;
    rdfs:label "is served by"@en ;
    rdfs:comment "relates a methodological approach to an entity that serves, realizes, supports, or instantiates it in an important way"@en .

:isSpecifiedBy
    a owl:ObjectProperty ;
    rdfs:domain :FoundationalEntity ;
    rdfs:range :MethodologicalApproach ;
    owl:inverseOf :specifies ;
    rdfs:label "is specified by"@en ;
    rdfs:comment "relates an entity to a methodological approach used to formally specify or define its behavior or meaning"@en .

:specifies
    a owl:ObjectProperty ;
    rdfs:domain :MethodologicalApproach ;
    rdfs:range :FoundationalEntity ;
    owl:inverseOf :isSpecifiedBy ;
    rdfs:label "specifies"@en ;
    rdfs:comment "relates a methodological approach to an entity whose behavior or meaning it is used to formally specify or define"@en .

#################################################################
# Metadata roots: subject areas, spaces, artifact kinds, tool kinds, literature
#################################################################

:SubjectArea
    a owl:Class ;
    rdfs:label "Subject area"@en ;
    rdfs:comment "research or application area relevant to the foundations of software languages and related disciplines"@en .

:SLE a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Software Language Engineering"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Language_engineering> ; rdfs:comment "area concerned with the engineering of software languages and related artifacts"@en .
:CC a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Compiler Construction"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Compiler#Compiler_construction> ; rdfs:comment "area concerned with the design and implementation of compilers"@en .
:PLT a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Programming Language Theory"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Programming_language_theory> ; rdfs:comment "area concerned with the formal study of programming languages and their properties"@en .
:TCS a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Theoretical Computer Science"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Theoretical_computer_science> ; rdfs:comment "area concerned with the mathematical and theoretical foundations of computer science"@en .
:SE a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Software Engineering"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Software_engineering> ; rdfs:comment "area concerned with systematic methods for the development and maintenance of software"@en .
:FM a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Formal Methods"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Formal_methods> ; rdfs:comment "area concerned with mathematically rigorous methods for specification, development, and verification"@en .
:KR a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Knowledge Representation & Reasoning"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning> ; rdfs:comment "area concerned with representing knowledge and supporting automated reasoning"@en .
:CL a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Computational Linguistics"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Computational_linguistics> ; rdfs:comment "area concerned with computational models and processing of natural language"@en .
:NLP a owl:NamedIndividual , :MetadataEntity , :SubjectArea ; rdfs:label "Natural Language Processing"@en ; owl:sameAs <https://en.wikipedia.org/wiki/Natural_language_processing> ; rdfs:comment "area concerned with computational techniques for analyzing and generating natural language"@en .

[] a owl:AllDifferent ; owl:distinctMembers ( :SLE :CC :PLT :TCS :SE :FM :KR :CL :NLP ) .

:TechnologicalSpace
    a owl:Class ;
    rdfs:label "Technological space"@en ;
    rdfs:comment "Technological spaces are families of related software-language technologies that share characteristic artifact kinds, metalanguages, tools, conformance relations, skills, and communities of practice. A technological space is not just a single language or formalism, but a working context in which artifacts are defined, manipulated, queried, transformed, validated, exchanged, and executed according to characteristic principles. This class represents such ecosystems."@en .


:generalizesSpace a owl:ObjectProperty ; rdfs:domain :TechnologicalSpace ; rdfs:range :TechnologicalSpace ; owl:inverseOf :specializesSpace ; rdfs:label "generalizes space"@en .
:specializesSpace a owl:ObjectProperty ; rdfs:domain :TechnologicalSpace ; rdfs:range :TechnologicalSpace ; owl:inverseOf :generalizesSpace ; rdfs:label "specializes space"@en .

:Grammarware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Grammarware"@en ; rdfs:comment "technological space centered on grammars, grammar formalisms, parsing, grammar analysis, and grammar transformation"@en .
:Modelware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Modelware"@en ; rdfs:comment "technological space centered on models, metamodels, model transformation, and model validation"@en .
:Programware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Programware"@en ; rdfs:comment "technological space centered on programs, programming languages, compilation, interpretation, and program analysis"@en .
:XMLware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "XMLware"@en ; rdfs:comment "technological space centered on XML documents, XML schemas, XML querying, XML transformation, and XML processing"@en .
:JSONware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "JSONware"@en ; rdfs:comment "technological space centered on JSON documents, JSON schemas, JSON querying, JSON transformation, and validation"@en .
:SQLware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "SQLware"@en ; rdfs:comment "technological space centered on relational schemas, relational data manipulation, querying, constraints, and database systems"@en .
:Ontoware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Ontoware"@en ; rdfs:comment "technological space centered on semantic data models, ontologies, semantic constraints, semantic queries, mappings, and reasoning"@en .
:Graphware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Graphware"@en ; rdfs:comment "technological space centered on graph-shaped data, graph querying, graph transformation, and graph databases"@en .
:APIware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "APIware"@en ; rdfs:comment "technological space centered on interface descriptions, service contracts, API documentation, and contract-oriented tooling"@en .
:Ruleware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Ruleware"@en ; rdfs:comment "technological space centered on rule artifacts, rule languages, rule engines, and symbolic rule-based reasoning"@en .
:Logicware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Logicware"@en ; rdfs:comment "technological space centered on logic programs, logical theories, symbolic inference, and logic-oriented programming systems"@en .
:Proofware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Proofware"@en ; rdfs:comment "technological space centered on formal proofs, proof languages, theorem provers, proof assistants, and mechanized reasoning"@en .
:Markupware a owl:NamedIndividual , :MetadataEntity , :TechnologicalSpace ; rdfs:label "Markupware"@en ; rdfs:comment "technological space centered on markup artifacts, markup languages, markup transformation, and markup-aware processors"@en  .

[] a owl:AllDifferent ; owl:distinctMembers ( :Grammarware :Modelware :Programware :XMLware :JSONware :SQLware :Ontoware :Graphware :APIware :Logicware :Ruleware :Proofware :Markupware ) .

:ArtifactKind a owl:Class ; rdfs:label "Artifact kind"@en .
:SoftwareTool a owl:Class ; rdfs:label "Software tool"@en .
:LiteratureReference a owl:Class ; rdfs:label "Literature reference"@en .

:hasArtifactKind a owl:ObjectProperty ; rdfs:domain :TechnologicalSpace ; rdfs:range :ArtifactKind ; owl:inverseOf :isArtifactKindOf ; rdfs:label "has artifact kind"@en .
:isArtifactKindOf a owl:ObjectProperty ; rdfs:domain :ArtifactKind ; rdfs:range :TechnologicalSpace ; owl:inverseOf :hasArtifactKind ; rdfs:label "is artifact kind of"@en .
:hasToolKind a owl:ObjectProperty ; rdfs:domain :TechnologicalSpace ; rdfs:range :SoftwareTool ; owl:inverseOf :isToolKindOf ; rdfs:label "has tool kind"@en .
:isToolKindOf a owl:ObjectProperty ; rdfs:domain :SoftwareTool ; rdfs:range :TechnologicalSpace ; owl:inverseOf :hasToolKind ; rdfs:label "is tool kind of"@en .
:elementOf a owl:ObjectProperty ; rdfs:domain :ArtifactKind ; rdfs:range :SoftwareLanguage ; owl:inverseOf :hasElementKind ; rdfs:label "element of"@en .
:hasElementKind a owl:ObjectProperty ; rdfs:domain :SoftwareLanguage ; rdfs:range :ArtifactKind ; owl:inverseOf :elementOf ; rdfs:label "has element kind"@en .
:conformsTo a owl:ObjectProperty ; rdfs:domain :ArtifactKind ; rdfs:range :ArtifactKind ; owl:inverseOf :hasConformingArtifactKind ; rdfs:label "conforms to"@en .
:hasConformingArtifactKind a owl:ObjectProperty ; rdfs:domain :ArtifactKind ; rdfs:range :ArtifactKind ; owl:inverseOf :conformsTo ; rdfs:label "has conforming artifact kind"@en .
:describesArtifactKind a owl:ObjectProperty ; rdfs:domain :ArtifactKind ; rdfs:range :ArtifactKind ; owl:inverseOf :isDescribedByArtifactKind ; rdfs:label "describes artifact kind"@en .
:isDescribedByArtifactKind a owl:ObjectProperty ; rdfs:domain :ArtifactKind ; rdfs:range :ArtifactKind ; owl:inverseOf :describesArtifactKind ; rdfs:label "is described by artifact kind"@en .
:processesArtifactKind a owl:ObjectProperty ; rdfs:domain :SoftwareTool ; rdfs:range :ArtifactKind ; owl:inverseOf :isProcessedByToolKind ; rdfs:label "processes artifact kind"@en .
:isProcessedByToolKind a owl:ObjectProperty ; rdfs:domain :ArtifactKind ; rdfs:range :SoftwareTool ; owl:inverseOf :processesArtifactKind ; rdfs:label "is processed by tool kind"@en .
:supportsLanguage a owl:ObjectProperty ; rdfs:domain :SoftwareTool ; rdfs:range :SoftwareLanguage ; owl:inverseOf :isSupportedByToolKind ; rdfs:label "supports language"@en .
:isSupportedByToolKind a owl:ObjectProperty ; rdfs:domain :SoftwareLanguage ; rdfs:range :SoftwareTool ; owl:inverseOf :supportsLanguage ; rdfs:label "is supported by tool kind"@en .

:hasLiteratureReference a owl:ObjectProperty ; rdfs:domain :TechnologicalSpace ; rdfs:range :LiteratureReference ; owl:inverseOf :isLiteratureReferenceFor ; rdfs:label "has literature reference"@en .
:isLiteratureReferenceFor a owl:ObjectProperty ; rdfs:domain :LiteratureReference ; rdfs:range :TechnologicalSpace ; owl:inverseOf :hasLiteratureReference ; rdfs:label "is literature reference for"@en .

:hasBibtexKey a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasEntryType a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasTitle a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasAuthorString a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasBooktitle a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasJournal a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasSeries a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasVolume a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasNumber a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasPages a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasPublisher a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasPublicationYear a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:gYear .
:hasDOI a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .
:hasURL a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:anyURI .
:hasInclusionRoleComment a owl:DatatypeProperty ; rdfs:domain :LiteratureReference ; rdfs:range xsd:string .

#################################################################
# Language taxonomy and language entities
#################################################################

:SoftwareLanguage
    a owl:Class ;
    rdfs:label "Software language"@en ;
    rdfs:seeAlso <https://en.wikipedia.org/wiki/Software_language> ;
    rdfs:comment "Concrete software languages (e.g., XML, SQL, OWL) are represented as individuals of this class. Language families are represented as subclasses. Artifact kinds capture the kinds of artifacts written in such languages."@en .

:ProgrammingLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Programming language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Programming_language> ; rdfs:comment "software language for expressing executable or interpretable programs"@en ; :hasArea :PLT , :SLE , :SE ; :hasSpace :Programware .
:ModelingLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Modeling language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Modeling_language> ; rdfs:comment "language for modeling systems"@en ; :hasArea :SLE , :SE , :FM ; :hasSpace :Modelware .
:Metalanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Metalanguage"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Metalanguage> ; rdfs:comment "language for describing languages"@en ; :hasArea :SLE , :CC ; :hasSpace :Grammarware .
:GrammarMetalanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :Metalanguage ; rdfs:label "Grammar metalanguage"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Metasyntax> ; rdfs:comment "metalanguage for expressing grammars"@en ; :hasArea :SLE , :CC ; :hasSpace :Grammarware .
:MetamodelingLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :Metalanguage ; rdfs:label "Metamodeling language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Metamodeling> ; rdfs:comment "metalanguage for expressing metamodels and defining modeling languages"@en ; :hasArea :SLE , :SE ; :hasSpace :Modelware .
:SchemaLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Schema language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Schema_(computer_science)> ; rdfs:comment "software language for expressing structural schemas of artifacts"@en ; :hasArea :SLE , :SE ; :hasSpace :XMLware .
:XMLSchemaLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SchemaLanguage ; rdfs:label "XML schema language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/XML_Schema_(W3C)> ; rdfs:comment "schema language for XML documents"@en ; :hasArea :SLE , :SE ; :hasSpace :XMLware .
:JSONSchemaLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SchemaLanguage ; rdfs:label "JSON schema language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/JSON_Schema> ; rdfs:comment "schema language for JSON documents"@en ; :hasArea :SLE , :SE ; :hasSpace :JSONware .
:OntologyLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Ontology language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Ontology_language> ; rdfs:comment "software language for expressing ontologies, vocabularies, axioms, and semantic conceptualizations"@en ; :hasArea :KR , :SLE ; :hasSpace :Ontoware .
:SemanticDataModelLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Semantic data-model language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Semantic_data_model> ; rdfs:comment "software language for representing semantic graph-shaped data models"@en ; :hasArea :KR , :SLE ; :hasSpace :Ontoware .
:PropertyGraphDataModelLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Property-graph data-model language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Property_graph> ; rdfs:comment "software language or data-model notation for property graphs"@en ; :hasArea :SE , :SLE ; :hasSpace :Graphware .
:QueryLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Query language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Query_language> ; rdfs:comment "software language for selecting, navigating, or retrieving information from artifacts"@en ; :hasArea :SLE , :SE , :KR ; :hasSpace :SQLware .
:XMLQueryLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :QueryLanguage ; rdfs:label "XML query language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/XQuery> ; :hasArea :SLE , :SE ; :hasSpace :XMLware .
:JSONQueryLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :QueryLanguage ; rdfs:label "JSON query language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/JSONPath> ; :hasArea :SLE , :SE ; :hasSpace :JSONware .
:RelationalQueryLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :QueryLanguage ; rdfs:label "Relational query language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/SQL> ; :hasArea :SE , :SLE ; :hasSpace :SQLware .
:SemanticQueryLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :QueryLanguage ; rdfs:label "Semantic query language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/SPARQL> ; :hasArea :KR , :SLE ; :hasSpace :Ontoware .
:GraphQueryLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :QueryLanguage ; rdfs:label "Graph query language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Graph_query_language> ; :hasArea :SE , :SLE ; :hasSpace :Graphware .
:TransformationLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Transformation language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Program_transformation> ; :hasArea :SLE , :SE , :CC ; :hasSpace :Modelware .
:GrammarTransformationLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :TransformationLanguage ; rdfs:label "Grammar transformation language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Program_transformation> ; :hasArea :SLE , :CC ; :hasSpace :Grammarware .
:ModelTransformationLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :TransformationLanguage ; rdfs:label "Model transformation language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Model_transformation> ; :hasArea :SLE , :SE ; :hasSpace :Modelware .
:DocumentTransformationLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :TransformationLanguage ; rdfs:label "Document transformation language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/XSLT> ; :hasArea :SLE , :SE ; :hasSpace :XMLware , :JSONware .
:ConstraintLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Constraint language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Constraint_programming> ; :hasArea :SLE , :SE , :KR ; :hasSpace :Ontoware .
:MappingLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Mapping language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Data_mapping> ; :hasArea :SLE , :SE , :KR ; :hasSpace :Ontoware .
:InterfaceDescriptionLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Interface description language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Interface_description_language> ; :hasArea :SE , :SLE ; :hasSpace :APIware .
:DataDefinitionLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Data definition language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Data_definition_language> ; :hasArea :SE , :SLE ; :hasSpace :SQLware .
:DataManipulationLanguage a owl:Class , :LanguageEntity ; rdfs:subClassOf :SoftwareLanguage ; rdfs:label "Data manipulation language"@en ; rdfs:seeAlso <https://en.wikipedia.org/wiki/Data_manipulation_language> ; :hasArea :SE , :SLE ; :hasSpace :SQLware .
