:ProgramArtifact :elementOf :ProgrammingLanguage .
:GrammarArtifact :elementOf :GrammarMetalanguage .
:ModelArtifact :elementOf :ModelingLanguage ; :conformsTo :MetamodelArtifact .
:MetamodelArtifact :elementOf :MetamodelingLanguage .
:XMLDocumentArtifact :elementOf :XML ; :conformsTo :XMLSchemaArtifact .
:XMLSchemaArtifact :elementOf :XMLSchemaLanguage ; :describesArtifactKind :XMLDocumentArtifact .
:JSONDocumentArtifact :elementOf :JSON ; :conformsTo :JSONSchemaArtifact .
:JSONSchemaArtifact :elementOf :JSONSchemaLanguage ; :describesArtifactKind :JSONDocumentArtifact .
:RelationalSchemaArtifact :elementOf :SQLDDL ; :describesArtifactKind :RelationalDataArtifact .
:RelationalDataArtifact :elementOf :SQLDML ; :conformsTo :RelationalSchemaArtifact .
:RelationalQueryArtifact :elementOf :SQLQuery .
:RDFGraphArtifact :elementOf :RDF ; :conformsTo :ShapeArtifact .
:OntologyArtifact :elementOf :OntologyLanguage ; :describesArtifactKind :RDFGraphArtifact .
:ShapeArtifact :elementOf :ConstraintLanguage ; :describesArtifactKind :RDFGraphArtifact .
:PropertyGraphArtifact :elementOf :PropertyGraphDataModelLanguage .
:GraphQueryArtifact :elementOf :GraphQueryLanguage .
:APIDescriptionArtifact :elementOf :InterfaceDescriptionLanguage .
:RuleArtifact :elementOf :RuleLanguage .
:LogicProgramArtifact :elementOf :LogicProgrammingLanguage .
:ProofArtifact :elementOf :ProofLanguage .
:MarkupArtifact :elementOf :MarkupLanguage .

:ParserGenerator a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Parser generator"@en .
:GrammarAnalyzer a owl:Class , :MetadataEntity ; rdfs:subClassOf :SoftwareTool ; rdfs:label "Grammar analyzer"@en .
